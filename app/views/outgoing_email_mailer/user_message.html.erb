<% @body.split("\n").each do |line| %>
  <% if line.strip.start_with?("<ul>", "<ul ") || line.strip.start_with?("<li>") || line.strip.start_with?("</ul>") %>
    <%= line.html_safe %>
  <% elsif line.present? %>
    <div><%= auto_link(line) %></div>
  <% else %>
    <br />
  <% end %>
<% end %>
<br />
<%= auto_link(t(".unsubscribe", unsubscribe_link: @unsubscribe_link)) %>