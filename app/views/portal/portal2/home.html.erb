<% content_for :title, t(".title", name: current_client.intake.preferred_name) %>

<% content_for :card do %>
  <h2 class="spacing-below-10"><%= t(".title", name: current_client.intake.preferred_name) %></h2>

  <% if @tax_returns.present? %>
    <% @tax_returns.each_with_index do |tax_return, index| %>
      <div class="spacing-below-25">
        <%= render "tax_return_card", tax_return: tax_return %>
      </div>

      <%= render 'portal/shared/message_my_tax_team2', tax_return: tax_return %>
    <% end %>
  <% end %>
<% end %>

