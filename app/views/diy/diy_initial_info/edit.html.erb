<% content_for :page_title, t("diy.initial_info.edit.title") %>

<section class="slab slab--white question-layout">
  <div class="grid">
    <div class="grid__item question-wrapper">
      <div class="main-content-inner">

        <%= form_with model: @form, url: diy_diy_initial_info_path, local: true, method: "put", builder: VitaMinFormBuilder, html: { class: "form-card form-card--long" } do |f| %>
          <h1 class="h2"><%= content_for(:page_title) %></h1>

          <div class="form-card__content">
            <%= f.cfa_input_field(:preferred_first_name, t("diy.initial_info.edit.first_name"), classes: ["form-width--long"]) %>
            <%= f.cfa_select(:state_of_residence, t("diy.initial_info.edit.state_of_residence"), DiyStates.name_value_pairs, include_blank: true) %>
            <%= f.cfa_input_field(:zip_code, t("diy.initial_info.edit.zip_code"), classes: ["form-width--zip"]) %>
          </div>

          <%= f.continue %>
        <% end %>
      </div>
    </div>        
  </div>
</section>

